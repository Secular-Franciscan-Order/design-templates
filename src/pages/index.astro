---
import templateData from "../data/templates.json";

const pageTitle = "Website Templates";
const pageDescription =
  "Unlisted template-preview menu for choosing a website design.";
const templates = templateData.templates;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f3ec;
        --panel: #fffdf8;
        --ink: #1c1a17;
        --muted: #5e625f;
        --rule: rgba(28, 26, 23, 0.14);
        --blue: #2f7fb0;
        --rust: #8d3d2a;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        min-height: 100vh;
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        line-height: 1.5;
      }

      a {
        color: inherit;
      }

      a:focus-visible {
        outline: 3px solid var(--blue);
        outline-offset: 4px;
      }

      main {
        width: min(100% - 40px, 1180px);
        margin: 0 auto;
        padding: 42px 0 64px;
      }

      .topline {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 24px;
        padding-bottom: 28px;
        border-bottom: 1px solid var(--rule);
      }

      .eyebrow {
        margin: 0 0 8px;
        color: var(--rust);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: 42px;
        font-weight: 850;
        line-height: 1.08;
      }

      .lede {
        max-width: 460px;
        margin: 0;
        color: var(--muted);
        font-size: 17px;
      }

      .template-list {
        margin-top: 38px;
      }

      .template-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 18px;
      }

      .template-card {
        min-width: 0;
        display: grid;
        grid-template-rows: auto 1fr;
        overflow: hidden;
        border: 1px solid var(--rule);
        background: var(--panel);
        text-decoration: none;
      }

      .thumb {
        aspect-ratio: 3 / 2;
        overflow: hidden;
        border-bottom: 1px solid var(--rule);
        background: #e7e1d5;
      }

      .thumb img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
      }

      .card-body {
        display: grid;
        gap: 12px;
        padding: 18px;
      }

      .label {
        width: 34px;
        height: 34px;
        display: inline-grid;
        place-items: center;
        border: 1px solid var(--rule);
        color: var(--rust);
        font-weight: 800;
      }

      .template-card:nth-child(2) .label {
        color: var(--blue);
      }

      .template-card:nth-child(3) .label {
        color: var(--ink);
      }

      .card-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
      }

      .card-title h3 {
        margin: 0;
        font-size: 20px;
        line-height: 1.2;
      }

      .card-body p {
        margin: 0;
        color: var(--muted);
        font-size: 15px;
      }

      .card-action {
        align-self: end;
        color: var(--blue);
        font-size: 14px;
        font-weight: 800;
      }

      @media (max-width: 860px) {
        main {
          width: min(100% - 28px, 1180px);
          padding-top: 30px;
        }

        .topline {
          display: block;
        }

        h1 {
          font-size: 34px;
        }

        .lede {
          margin-top: 14px;
        }

        .template-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="topline">
        <div>
          <p class="eyebrow">Website templates</p>
          <h1>Choose a template for your website.</h1>
        </div>
        <p class="lede">
          Browse these live, ready-to-use templates. Pick the one you like,
          then I'll build your site on it.
        </p>
      </header>

      <section class="template-list" aria-label="Available templates">
        <div class="template-grid">
          {
            templates.map((template) => (
              <a
                class="template-card"
                href={`/preview?d=${template.slug}&device=desktop`}
              >
                <div class="thumb">
                  <img
                    src={`/thumbs/${template.thumb}`}
                    alt={`${template.title} homepage preview`}
                    loading="eager"
                    decoding="async"
                    width="720"
                    height="480"
                  />
                </div>
                <div class="card-body">
                  <div class="card-title">
                    <span class="label">{template.label}</span>
                    <h3>{template.title}</h3>
                  </div>
                  <p>{template.blurb}</p>
                  <span class="card-action">View template</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </main>
  </body>
</html>
