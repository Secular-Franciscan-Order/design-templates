---
const pageTitle = "Design Templates";
const pageDescription =
  "Unlisted design-preview gallery for live community review.";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f7f4ec;
        --panel: #fffdf8;
        --ink: #1c1a17;
        --muted: #5f5a51;
        --rule: rgba(28, 26, 23, 0.16);
        --accent: #7a2e2a;
        --accent-soft: #efe0dc;
      }

      * {
        box-sizing: border-box;
      }

      body {
        min-height: 100vh;
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family:
          ui-serif, Georgia, Cambria, "Times New Roman", Times, serif;
        line-height: 1.5;
      }

      main {
        width: min(100% - 40px, 920px);
        margin: 0 auto;
        padding: 72px 0;
      }

      .eyebrow {
        margin: 0 0 20px;
        color: var(--accent);
        font-family:
          ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      h1 {
        max-width: 760px;
        margin: 0;
        font-size: 52px;
        font-weight: 500;
        line-height: 1.05;
      }

      .lede {
        max-width: 680px;
        margin: 24px 0 0;
        color: var(--muted);
        font-size: 21px;
      }

      .status {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
        margin-top: 48px;
      }

      .status-card {
        min-height: 144px;
        padding: 22px;
        border: 1px solid var(--rule);
        background: var(--panel);
      }

      .status-card strong {
        display: block;
        margin-bottom: 10px;
        color: var(--accent);
        font-family:
          ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .status-card p {
        margin: 0;
        color: var(--muted);
      }

      .notice {
        margin-top: 42px;
        padding: 18px 20px;
        border: 1px solid var(--rule);
        background: var(--accent-soft);
        color: #39201f;
        font-family:
          ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI",
          sans-serif;
        font-size: 15px;
      }

      @media (max-width: 720px) {
        main {
          width: min(100% - 28px, 920px);
          padding: 42px 0;
        }

        h1 {
          font-size: 38px;
        }

        .lede {
          font-size: 18px;
        }

        .status {
          grid-template-columns: 1fr;
          margin-top: 34px;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <p class="eyebrow">Design preview infrastructure</p>
      <h1>Design Templates is ready for review-gallery scaffolding.</h1>
      <p class="lede">
        This placeholder confirms the static Astro project, Cloudflare Pages
        build pipeline, and noindex headers before the first live design review
        is added.
      </p>

      <section class="status" aria-label="Pipeline readiness">
        <article class="status-card">
          <strong>Static</strong>
          <p>Astro is configured for a static Cloudflare Pages build.</p>
        </article>
        <article class="status-card">
          <strong>Noindex</strong>
          <p>Pages headers and document metadata keep review demos unlisted.</p>
        </article>
        <article class="status-card">
          <strong>Reusable</strong>
          <p>The real gallery and extracted design pages land in a later PR.</p>
        </article>
      </section>

      <p class="notice">
        This is an infrastructure placeholder. No design review content is live
        yet.
      </p>
    </main>
  </body>
</html>
