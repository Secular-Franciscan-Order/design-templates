---
import reviewData from "../data/reviews.json";

const pageTitle = "Design Reviews";
const pageDescription =
  "Unlisted design-preview gallery for live community review.";
const reviews = reviewData.reviews;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex,nofollow" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f3ec;
        --panel: #fffdf8;
        --ink: #1c1a17;
        --muted: #5e625f;
        --rule: rgba(28, 26, 23, 0.14);
        --blue: #2f7fb0;
        --green: #5a8f6b;
        --rust: #8d3d2a;
        --gold: #b78b3e;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        min-height: 100vh;
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        line-height: 1.5;
      }

      a {
        color: inherit;
      }

      a:focus-visible {
        outline: 3px solid var(--blue);
        outline-offset: 4px;
      }

      main {
        width: min(100% - 40px, 1180px);
        margin: 0 auto;
        padding: 42px 0 64px;
      }

      .topline {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 24px;
        padding-bottom: 28px;
        border-bottom: 1px solid var(--rule);
      }

      .eyebrow {
        margin: 0 0 8px;
        color: var(--rust);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-family:
          Georgia, Cambria, "Times New Roman", Times, serif;
        font-size: 46px;
        font-weight: 500;
        line-height: 1.08;
      }

      .lede {
        max-width: 460px;
        margin: 0;
        color: var(--muted);
        font-size: 17px;
      }

      .review-list {
        display: grid;
        gap: 42px;
        margin-top: 38px;
      }

      .review-heading {
        display: flex;
        align-items: end;
        justify-content: space-between;
        gap: 20px;
        margin-bottom: 18px;
      }

      .review-heading h2 {
        margin: 0;
        font-size: 23px;
        line-height: 1.2;
      }

      .meta {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 8px;
        color: var(--muted);
        font-size: 14px;
      }

      .status {
        min-height: 32px;
        display: inline-flex;
        align-items: center;
        padding: 0 12px;
        border: 1px solid rgba(90, 143, 107, 0.4);
        background: #eef4ee;
        color: #315f40;
        font-size: 13px;
        font-weight: 700;
      }

      .design-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .design-card {
        min-width: 0;
        display: grid;
        grid-template-rows: auto 1fr;
        overflow: hidden;
        border: 1px solid var(--rule);
        background: var(--panel);
        text-decoration: none;
      }

      .thumb {
        aspect-ratio: 3 / 2;
        overflow: hidden;
        border-bottom: 1px solid var(--rule);
        background: #e7e1d5;
      }

      .thumb img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
      }

      .card-body {
        display: grid;
        gap: 12px;
        padding: 18px;
      }

      .label {
        width: 34px;
        height: 34px;
        display: inline-grid;
        place-items: center;
        border: 1px solid var(--rule);
        color: var(--rust);
        font-weight: 800;
      }

      .design-card:nth-child(2) .label {
        color: var(--blue);
      }

      .design-card:nth-child(3) .label {
        color: var(--ink);
      }

      .card-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
      }

      .card-title h3 {
        margin: 0;
        font-size: 20px;
        line-height: 1.2;
      }

      .card-body p {
        margin: 0;
        color: var(--muted);
        font-size: 15px;
      }

      .card-action {
        align-self: end;
        color: var(--blue);
        font-size: 14px;
        font-weight: 800;
      }

      @media (max-width: 860px) {
        main {
          width: min(100% - 28px, 1180px);
          padding-top: 30px;
        }

        .topline,
        .review-heading {
          display: block;
        }

        h1 {
          font-size: 38px;
        }

        .lede {
          margin-top: 14px;
        }

        .status {
          margin-top: 14px;
        }

        .design-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="topline">
        <div>
          <p class="eyebrow">Design reviews</p>
          <h1>Live design directions for community review.</h1>
        </div>
        <p class="lede">
          Review the live homepage directions, choose a favorite, then reply by
          email with your preference.
        </p>
      </header>

      <section class="review-list" aria-label="Available reviews">
        {
          reviews.map((review) => (
            <article>
              <div class="review-heading">
                <div>
                  <h2>{review.title}</h2>
                  <div class="meta">
                    <span>{review.date}</span>
                    <span aria-hidden="true">/</span>
                    <span>{review.designs.length} directions</span>
                  </div>
                </div>
                <span class="status">{review.status}</span>
              </div>

              <div class="design-grid">
                {review.designs.map((design) => (
                  <a
                    class="design-card"
                    href={`/preview?d=${review.slug}/${design.slug}&device=desktop`}
                  >
                    <div class="thumb">
                      <img
                        src={`/thumbs/${design.thumb}`}
                        alt={`${design.title} homepage preview`}
                        loading="lazy"
                        width="720"
                        height="480"
                      />
                    </div>
                    <div class="card-body">
                      <div class="card-title">
                        <span class="label">{design.label}</span>
                        <h3>{design.title}</h3>
                      </div>
                      <p>{design.blurb}</p>
                      <span class="card-action">Open preview</span>
                    </div>
                  </a>
                ))}
              </div>
            </article>
          ))
        }
      </section>
    </main>
  </body>
</html>
