---
import templateData from "../data/templates.json";

const siteUrl = "https://ofs-demos.endian.dev";
const pageTitle = "Websites for Secular Franciscan Fraternities";
const pageDescription =
  "Simple, welcoming websites for Secular Franciscan (OFS) fraternities. Browse ready-made designs, pick the one you like, and I'll build it for your community.";
const canonicalUrl = `${siteUrl}/`;
const ogImage = `${siteUrl}/thumbs/st-margaret-2026/direction-a.jpg`;
const contactEmail = "bill@endian.dev";

const structuredData = {
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  name: pageTitle,
  description: pageDescription,
  url: canonicalUrl,
  email: contactEmail,
  image: ogImage,
  serviceType:
    "Website design and development for Secular Franciscan fraternities",
  audience: {
    "@type": "Audience",
    audienceType: "Secular Franciscan Order fraternities"
  }
};

const templates = templateData.templates;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="index,follow" />
    <meta name="description" content={pageDescription} />
    <title>{pageTitle}</title>
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Franciscan Fraternity Websites" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:image" content={ogImage} />

    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify(structuredData)}
    />
    <style>
      :root {
        color-scheme: light;
        --bg: #f6f3ec;
        --panel: #fffdf8;
        --ink: #1c1a17;
        --muted: #5e625f;
        --rule: rgba(28, 26, 23, 0.14);
        --blue: #2f7fb0;
        --rust: #8d3d2a;
      }

      * {
        box-sizing: border-box;
      }

      html {
        background: var(--bg);
      }

      body {
        min-height: 100vh;
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family:
          Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        line-height: 1.5;
      }

      a {
        color: inherit;
      }

      a:focus-visible {
        outline: 3px solid var(--blue);
        outline-offset: 4px;
      }

      main {
        width: min(100% - 40px, 1180px);
        margin: 0 auto;
        padding: 42px 0 64px;
      }

      .topline {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 32px;
        padding-bottom: 28px;
        border-bottom: 1px solid var(--rule);
      }

      .intro {
        max-width: 620px;
      }

      .eyebrow {
        margin: 0 0 8px;
        color: var(--rust);
        font-size: 13px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      h1 {
        margin: 0;
        font-size: 42px;
        font-weight: 850;
        line-height: 1.08;
      }

      .lede {
        max-width: 540px;
        margin: 16px 0 0;
        color: var(--muted);
        font-size: 17px;
      }

      .contact-card {
        flex: 0 0 auto;
        width: min(280px, 100%);
        display: grid;
        gap: 6px;
        padding: 20px;
        border: 1px solid var(--rule);
        background: var(--panel);
      }

      .contact-label {
        margin: 0;
        color: var(--rust);
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .contact-email {
        color: var(--blue);
        font-size: 19px;
        font-weight: 800;
        text-decoration: none;
        word-break: break-word;
      }

      .contact-email:hover {
        text-decoration: underline;
      }

      .contact-note {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
      }

      .template-list {
        margin-top: 38px;
      }

      .section-label {
        margin: 0 0 16px;
        color: var(--muted);
        font-size: 14px;
        font-weight: 800;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .template-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 18px;
      }

      .template-card {
        min-width: 0;
        display: grid;
        grid-template-rows: auto 1fr;
        overflow: hidden;
        border: 1px solid var(--rule);
        background: var(--panel);
        text-decoration: none;
      }

      .thumb {
        aspect-ratio: 3 / 2;
        overflow: hidden;
        border-bottom: 1px solid var(--rule);
        background: #e7e1d5;
      }

      .thumb img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
      }

      .card-body {
        display: grid;
        gap: 12px;
        padding: 18px;
      }

      .label {
        width: 34px;
        height: 34px;
        display: inline-grid;
        place-items: center;
        border: 1px solid var(--rule);
        color: var(--rust);
        font-weight: 800;
      }

      .template-card:nth-child(2) .label {
        color: var(--blue);
      }

      .template-card:nth-child(3) .label {
        color: var(--ink);
      }

      .card-title {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
      }

      .card-title h3 {
        margin: 0;
        font-size: 20px;
        line-height: 1.2;
      }

      .card-body p {
        margin: 0;
        color: var(--muted);
        font-size: 15px;
      }

      .card-action {
        align-self: end;
        color: var(--blue);
        font-size: 14px;
        font-weight: 800;
      }

      @media (max-width: 860px) {
        main {
          width: min(100% - 28px, 1180px);
          padding-top: 30px;
        }

        .topline {
          display: block;
        }

        h1 {
          font-size: 34px;
        }

        .contact-card {
          width: 100%;
          margin-top: 24px;
        }

        .template-grid {
          grid-template-columns: 1fr;
        }
      }
    </style>
  </head>
  <body>
    <main>
      <header class="topline">
        <div class="intro">
          <p class="eyebrow">For Secular Franciscan fraternities</p>
          <h1>Help people find your fraternity.</h1>
          <p class="lede">
            I build simple, warm websites for Secular Franciscan communities.
            Each design below is a complete, working site — picture your
            fraternity in its place, then get in touch and I'll build it for you.
          </p>
        </div>
        <aside class="contact-card" aria-label="Contact">
          <p class="contact-label">Get in touch</p>
          <a
            class="contact-email"
            href="mailto:bill@endian.dev?subject=OFS%20Community%20Website%20Inquiry"
          >
            bill@endian.dev
          </a>
          <p class="contact-note">See one you like? Email me.</p>
        </aside>
      </header>

      <section class="template-list" aria-label="Available templates">
        <h2 class="section-label">Choose a design</h2>
        <div class="template-grid">
          {
            templates.map((template) => (
              <a
                class="template-card"
                href={`/preview?d=${template.slug}&device=desktop`}
              >
                <div class="thumb">
                  <img
                    src={`/thumbs/${template.thumb}`}
                    alt={`${template.title} homepage preview`}
                    loading="eager"
                    decoding="async"
                    width="720"
                    height="480"
                  />
                </div>
                <div class="card-body">
                  <div class="card-title">
                    <span class="label">{template.label}</span>
                    <h3>{template.title}</h3>
                  </div>
                  <p>{template.blurb}</p>
                  <span class="card-action">View template</span>
                </div>
              </a>
            ))
          }
        </div>
      </section>
    </main>
  </body>
</html>
